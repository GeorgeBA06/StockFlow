<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.MainController"
      spacing="10"
      alignment="CENTER">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <Label text="Warehouse Client" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label fx:id="statusLabel" text="Connecting..." style="-fx-font-size: 14px;"/>
    <Button text="Create User" onAction="#openCreateUserDialog"/>
</VBox>