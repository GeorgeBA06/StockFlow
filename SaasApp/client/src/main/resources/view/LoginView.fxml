<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx = "http://javafx.com/fxml"
      alignment="CENTER"
      fx:controller="org.example.client.controller.LoginController"
      spacing="12"
      prefWidth="420"
      prefHeight="320"
      style="-fx-background-color: #F8FAFC;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Sign In"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>

    <TextField fx:id="emailField"
               promptText="Email"
               maxWidth="260"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="260"/>

    <Button text="Login"
            onAction="#onLogin"
            maxWidth="260"
            style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Button text="Create Account"
            onAction="#onOpenRegister"
            maxWidth="260"
            style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="resultLabel"
           wrapText="true"
           maxWidth="260"
           style="-fx-text-fill: #B91C1C;"/>
</VBox>