<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.CreateUserController"
      spacing="12"
      alignment="CENTER"
      prefWidth="420"
      prefHeight="360"
      style="-fx-background-color: #F8FAFC;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Create Account"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>

        <TextField fx:id="nameField"
                   promptText="Enter name"
                   prefWidth="240.0"
                   style="-fx-background-color: #F7FBFD; -fx-border-color: #D7E8F1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 12 10 12; -fx-font-size: 13px;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Enter password"
                       prefWidth="240.0"
                       style="-fx-background-color: #F7FBFD; -fx-border-color: #D7E8F1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 12 10 12; -fx-font-size: 13px;"/>


        <TextField fx:id="emailField"
                   promptText="Enter email"
                   prefWidth="240.0"
                   style="-fx-background-color: #F7FBFD; -fx-border-color: #D7E8F1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 12 10 12; -fx-font-size: 13px;"/>


    <Button text="Register"
            onAction="#onCreate"
            maxWidth="260"
            style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Button text="Cancel"
            onAction="#onCancel"
            maxWidth="260"
            style="-fx-background-color: #CBD5E1; -fx-text-fill: #0F172A; -fx-font-weight: bold;"/>

    <Label fx:id="resultLabel"
           wrapText="true"
           maxWidth="260"
           style="-fx-text-fill: #B91C1C;"/>

</VBox>